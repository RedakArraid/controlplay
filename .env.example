APP_ENV=development
APP_SECRET_KEY=change-me-in-prod
ADMIN_USERNAME=admin@gmail.com
ADMIN_PASSWORD=admin123
BASE_URL=http://localhost:${APP_PORT:-8000}

APP_PORT=8000
DB_PORT=5432
REDIS_PORT=6379

DATABASE_URL=postgresql+psycopg2://controlplay:controlplay@db:5432/controlplay
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Broadlink
BROADLINK_IP=192.168.1.250
BROADLINK_DRY_RUN=true
IR_CODE_HDMI1=hdmi1_code_placeholder
IR_CODE_HDMI2=hdmi2_code_placeholder
IR_CODE_POWER=power_code_placeholder

# Paystack (minimum: PAYSTACK_SECRET_KEY pour init + verify)
PAYSTACK_PUBLIC_KEY=pk_test_xxx
PAYSTACK_SECRET_KEY=sk_test_xxx
# Optionnel au départ : obligatoire en prod pour sécuriser POST /webhooks/paystack
PAYSTACK_WEBHOOK_SECRET=whsec_xxx
# Devise (défaut XOF). Pour NGN, mettre PAYSTACK_CURRENCY=NGN et PAYSTACK_AMOUNT_MULTIPLIER=100
PAYSTACK_CURRENCY=XOF
# Paystack semble attendre des sous-unités pour XOF (×100).
PAYSTACK_AMOUNT_MULTIPLIER=100

# CinetPay
CINETPAY_API_KEY=api_key_xxx
CINETPAY_SITE_ID=site_id_xxx
CINETPAY_SECRET_KEY=secret_xxx
CINETPAY_WEBHOOK_SECRET=whsec_xxx

# App options
AUTO_CREATE_SCHEMA=false

